# =========================
# 🔍 ANOMALY DETECTION
# =========================
def detect_anomalies(df):
    model = IsolationForest(contamination=0.2, random_state=42)
    df['anomaly'] = model.fit_predict(df[['cost']])
    return df[df['anomaly'] == -1]

# =========================
# 🧠 CFO ENGINE
# =========================
def fallback_cfo(row):
    cost = row['cost']
    usage = row['usage']
    instances = row['instances']

    if instances > 10:
        issue = "Over-provisioned infrastructure"
    elif usage > 85:
        issue = "High utilization risk"
    else:
        issue = "Stable"

    excess = max(0, cost - 500000)
    yearly_loss = excess * 12

    optimized_cost = int(cost * 0.65)
    savings = cost - optimized_cost

    return f"""
🚨 HIGH PRIORITY

Issue: {issue}

Financial Impact:
₹{cost:,}/month  
₹{yearly_loss:,}/year loss  

Decision:
Optimize infrastructure

Scenario:
Without action → ₹{cost*12:,}/year  
Optimized → ₹{optimized_cost*12:,}/year  

Savings:
₹{savings:,}/month  

Confidence: 80%
"""

# =========================
# 📜 AUDIT LOG
# =========================
def log_action(data):
    with open("audit_log.json", "a") as f:
        f.write(json.dumps({
            "time": str(datetime.now()),
            "event": data
        }) + "\n")

# =========================
# 📊 DATA INPUT
# =========================
file = st.file_uploader("Upload Enterprise Dataset")

if file:
    df = pd.read_csv(file)
else:
    df = pd.DataFrame({
        "month": ["Jan", "Feb", "Mar", "Apr", "May"],
        "service": ["EC2", "EC2", "EC2", "EC2", "EC2"],
        "cost": [450000, 780000, 500000, 850000, 480000],
        "usage": [65, 92, 68, 96, 66],
        "instances": [5, 14, 6, 16, 5]
    })

# =========================
# 🔍 PROCESS DATA
# =========================
anomalies = detect_anomalies(df)

results = []
for _, row in anomalies.iterrows():
    insight = fallback_cfo(row)

    log_action({
        "month": row['month'],
        "insight": insight
    })

    results.append({
        "Month": row['month'],
        "Service": row['service'],
        "Insight": insight,
        "Cost": row['cost']
    })

# =========================
# 💰 KPI CALCULATIONS
# =========================
total_cost = anomalies['cost'].sum() if not anomalies.empty else 0
optimized = int(total_cost * 0.65) if total_cost else 0

# =========================
# 🚨 ALERT
# =========================
if total_cost > 0:
    st.error("🚨 CFO ALERT: Financial inefficiency detected — Immediate action required")

